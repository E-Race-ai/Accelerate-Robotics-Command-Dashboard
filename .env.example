# Server
PORT=3000
NODE_ENV=development

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# Admin seed account — used on first run to create the initial admin user
ADMIN_EMAIL=admin@acceleraterobotics.ai
ADMIN_PASSWORD=change-me

# Optional second admin seed account (e.g. co-founder, ops lead)
ADMIN2_EMAIL=
ADMIN2_PASSWORD=

# Comma-separated emails that should always have role='admin'. Self-heals on every boot.
# Covers users created via invite flows or legacy seeds that didn't set a role.
BOOTSTRAP_ADMIN_EMAILS=

# Database (libsql / Turso). For local dev, point at a local SQLite file:
#   DATABASE_URL=file:./data/accelerate.db
# For production (Turso), point at the hosted URL and provide the auth token:
#   DATABASE_URL=libsql://<your-db>-<org>.aws-us-west-2.turso.io
#   DATABASE_AUTH_TOKEN=<token from `turso db tokens create <db>` or Turso dashboard>
DATABASE_URL=file:./data/accelerate.db
DATABASE_AUTH_TOKEN=

# Resend API key — get one at https://resend.com
RESEND_API_KEY=re_your_api_key_here

# Resend verified sender — must match a verified domain in Resend
EMAIL_FROM=notifications@acceleraterobotics.ai

# WHY: Required for AI-powered market research in the prospect pipeline and proposal narrative generation (/api/narrate)
ANTHROPIC_API_KEY=sk-ant-your-key-here
